<Window x:Class="MorganStanley.ComposeUI.DesktopAgent.ResolverUI.WPF.ResolverUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MorganStanley.ComposeUI.DesktopAgent.ResolverUI.WPF"
        mc:Ignorable="d"
        Title="ResolverUI" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="AppMetadataList" HorizontalAlignment="Center" VerticalAlignment="Center" IsReadOnly="True" MouseDoubleClick="SelectAppMetadata" />
        <Button Content="Cancel" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnCancelButtonClick" />
    </Grid>
</Window>
